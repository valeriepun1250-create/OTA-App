# 雲端開發階段建議用 Postgres (Supabase/Neon/Railway)
# 院內遷移時改 sqlserver:// 即可
DATABASE_URL="postgresql://user:password@localhost:5432/ota_amp?schema=public"

# Optional: comma-separated hosts for Next.js Server Actions CSRF allowlist
# Example: NEXT_SERVER_ACTIONS_ALLOWED_ORIGINS="myhost-3000.app.github.dev"
NEXT_SERVER_ACTIONS_ALLOWED_ORIGINS=""
